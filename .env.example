# Required: OpenAI key powers screen description, summaries, replies, and Whisper STT.
OPENAI_API_KEY=your_openai_key_here

# Optional: ElevenLabs key for high-quality TTS. Without it the cat falls
# back to the system speech synthesizer (browser TTS).
ELEVENLABS_API_KEY=your_elevenlabs_key_here_optional

# Optional model overrides. Defaults to gpt-4o-mini for both text and vision.
# OPENAI_TEXT_MODEL=gpt-4o-mini
# OPENAI_VISION_MODEL=gpt-4o-mini

# Google Calendar (OAuth2 Desktop App credentials)
# Create at: https://console.cloud.google.com → APIs → Credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Microsoft Outlook (Azure App Registration)
# Create at: https://portal.azure.com → App Registrations
OUTLOOK_CLIENT_ID=your_azure_app_client_id_here
OUTLOOK_TENANT_ID=common

# Qwen3 TTS (Alibaba DashScope)
# Get key at: https://www.alibabacloud.com/help/en/model-studio/get-api-key
DASHSCOPE_API_KEY=your_dashscope_api_key_here
